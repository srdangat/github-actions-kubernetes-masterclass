# Stage 1: Build
FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux \
    go build -o skillpulse .

# Stage 2: Runtime
FROM gcr.io/distroless/static-debian12

COPY --from=builder /app/skillpulse /skillpulse

EXPOSE 8080

ENTRYPOINT ["/skillpulse"]